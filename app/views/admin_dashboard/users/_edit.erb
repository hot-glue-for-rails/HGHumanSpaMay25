<%= turbo_frame_tag "admin_dashboard__#{dom_id(user)}" do  %>
<div class="cell editable" style="position: relative;">
  <% if user.errors.any? %>
  <%= render(partial: "admin_dashboard/errors", locals: {resource: user }) %>
  <% end %>
  <h2>Editing <%= user.name %></h2>
  <%= form_with model: user,
   url: admin_dashboard_family_user_path(family,user) do |f| %>
    <%=  render partial: "admin_dashboard/users/form", locals: {:user => user, f: f}.merge(family ? {family: family} : {}) %>
  
  <% end %>
  
</div>
<% end %>
