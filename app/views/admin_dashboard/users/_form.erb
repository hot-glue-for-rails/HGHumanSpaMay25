<div class="row">
  <div class='col-md-2 cell--user--email' >  
    <span class='<%= "alert alert-danger" if user.errors.details.keys.include?(:email) %>'  >
        <%= f.text_field :email, value: user.email, autocomplete: 'off', size: 40, class: 'form-control', type: '' %>
       
      
      <label class='text-muted small form-text' for=''>Email</label>
    </span>
   
  </div>
  <div class='col-md-2 cell--user--name' >  
    <span class='<%= "alert alert-danger" if user.errors.details.keys.include?(:name) %>'  >
        <%= f.text_field :name, value: user.name, autocomplete: 'off', size: 40, class: 'form-control', type: '' %>
       
      
      <label class='text-muted small form-text' for=''>Name</label>
    </span>
   
  </div>

  <div class="col-md-2">
    <%= link_to "Cancel", edit_admin_dashboard_family_path(family),  {class: "btn btn-secondary"} %>
    <%= f.submit "Save", class: "btn btn-primary pull-right" %>
  </div>
</div>
