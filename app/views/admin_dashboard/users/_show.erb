<div class='hg-col col-sm-2 user--email'> <%= user.email %></div>
<div class='hg-col col-sm-2 user--name'> <%= user.name %></div>









<div class=" scaffold-line-buttons col-md-2" >
  

  
    <%= form_with url: admin_dashboard_family_user_path(family,user), html: {data: {'turbo-confirm': "Are you sure you want to delete #{ user.name }?" }, style: "display: inline-block;"}, method: :delete do |f| %>
      <%= f.submit "Delete".html_safe,  class: "delete-user-button btn btn-primary btn-sm" %>
    <% end %>
  

  
  <%= link_to "Edit ".html_safe, edit_admin_dashboard_family_user_path(family,user), disable_with: "Loading...", class: "edit-user-button btn btn-primary btn-sm" %>
  
</div>
