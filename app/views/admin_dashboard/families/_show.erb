<div class='hg-col col-sm-2 family--name'> <%= family.name %></div>




  
  
  
    
    
    
    
    
    <div class="col-sm-4 scaffold-downnest"  >
    
    <%= render partial: "admin_dashboard/users/list", locals: {
        family: family,
        users: family.users
      }
      .merge({nested_for: "family-#{family.id}"})
      
    %>
    </div>
  
  






<div class=" scaffold-line-buttons col-md-2" >
  

  
    <%= form_with url: admin_dashboard_family_path(family), html: {data: {'turbo-confirm': "Are you sure you want to delete #{ family.name }?" }, style: "display: inline-block;"}, method: :delete do |f| %>
      <%= f.submit "Delete".html_safe,  class: "delete-family-button btn btn-primary btn-sm" %>
    <% end %>
  

  
  <%= link_to "Edit ".html_safe, edit_admin_dashboard_family_path(family), disable_with: "Loading...", class: "edit-family-button btn btn-primary btn-sm" %>
  
</div>
